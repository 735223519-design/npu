def CDT_of_Pore(Broken_Line_list, FileInputPath, holes_list, Visualization=False):
    """
    对折线化之后的孔隙轮廓烧结纳米银区域进行约束三角剖分
    参数:
        Broken_Line_list: 所有轮廓的折线列表(每个元素是Nx2的Numpy数组)
        FileInputPath: 原始图像路径(用于获取尺寸)
        holes_list:  不想进行三角剖分的区域内部的一个点(用于标识区域)
        Visualization: 是否进行可视化
    返回:
        B: 三角剖分结果字典
    """
    # 1. 读取图像获取尺寸
    img = io.imread(FileInputPath)
    if len(img.shape) > 2:
        img = img[:, :, 0]
    height, width = img.shape[:2]

    # 2.0 约束三角剖分数据准备(vertices)
    # 约束三角剖分的四条外边界对应的四个顶点
    external_boundary = np.array([[0, 0], [width, 0], [width, height], [0, height]])
    # 准备待三角化的多边形顶点坐标,包含边界顶点与轮廓顶点
    vertices = np.vstack([external_boundary] + [contour for contour in Broken_Line_list])
    # 确保输出的顶点vertices是2维数组
    vertices = np.atleast_2d(vertices)
    # 构建顶点索引映射(为每个顶点分配唯一索引,方便后续定义约束边)
    vertex_indices = {tuple(v): i for i, v in enumerate(vertices)}

    # 3.0 约束三角剖分数据准备(segments)
    # 构建约束边的顶点索引对(triangle库要求约束边以顶点索引对的形式提供)
    segments = []
    # 添加四条外边界约束边
    for i in range(len(external_boundary)):
        # tuple()将NumPy数组转换为Python元组,pt1是外边界顶点的坐标值
        pt1 = tuple(external_boundary[i])
        # %len(contour)是经典的循环索引技巧
        pt2 = tuple(external_boundary[(i + 1) % 4])
        # vertex_indices[pt1](根据坐标pt1查询字典,获取该点的唯一索引),将这条边的索引添加到segments
        segments.append([vertex_indices[pt1], vertex_indices[pt2]])
    # 添加孔隙边界约束边
    for contour in Broken_Line_list:   # 遍历每个孔隙轮廓
        for i in range(len(contour)):   # 遍历孔隙的每个顶点
            pt1 = tuple(contour[i])
            pt2 = tuple(contour[(i + 1) % len(contour)])
            segments.append([vertex_indices[pt1], vertex_indices[pt2]])
    # 将约束边的顶点索引对列表(segments)转为NumPy数组
    segments = np.array(segments, dtype=np.int32)

    # 4.0 执行约束三角剖分
    # 输入的参数vertices/segments/holes
    A = {
        'vertices': vertices,  # 顶点vertices
        'segments': segments,  # 将约束边的顶点索引对列表
        'holes': holes_list  # 使用传入的孔洞标识点
    }
    # 执行约束三角剖分
    # p 强制保留输入的所有约束边(如孔隙轮廓)
    # q30 生成三角形的最小角度 ≥ 30°
    # a20 限制三角形最大面积为 20
    # Y	禁止在约束边上插入新顶点
    # S100	限制生成网格的顶点数量(如 ≤ 100)
    B = tr.triangulate(A, 'pa20')  # 'p'表示约束剖分
    # 返回的B中包含
    # vertices网格中所有顶点的坐标
    # triangles三角形的顶点索引
    # edges所有边的顶点索引

    # 5.0 保存可视化结果
    if Visualization:
        dpi = 100
        fig = plt.figure(figsize=(width / dpi, height / dpi), dpi=dpi)
        ax = plt.Axes(fig, [0, 0, 1, 1])
        fig.add_axes(ax)
        ax.set_xlim(0, width)  # X轴从0到图像宽度
        ax.set_ylim(height, 0)  # 图像坐标系原点在左上角,不这样绘制的图像会上下颠倒
        ax.axis('off')  # 隐藏坐标轴和边框,节省边缘空间,使图像充满画布
        # 绘制Delaunay三角网
        # tr.plot(ax,
        #         vertices=B['vertices'],
        #         triangles=B['triangles'],
        #         vertex_marker='o',
        #         edge_color='blue',
        #         triangle_color='gray')
        # 绘制Voronoi图
        points = B['vertices']
        vor = Voronoi(points)
        # 可视化Voronoi边(红色半透明)
        # (p1, p2)是一对Voronoi图的顶点索引
        for i, (p1, p2) in enumerate(vor.ridge_vertices):
            if p1 != -1 and p2 != -1:  # 只绘制有限远的边
                ax.plot(vor.vertices[[p1, p2], 0], vor.vertices[[p1, p2], 1], 'r-', alpha=1, linewidth=0.5)
        # 绘制孔隙轮廓(黑色填充)
        for contour in Broken_Line_list:
            contour = np.array(contour)
            # 若轮廓首尾没有闭合,则通过np.vstack添加起点到末尾
            if not np.array_equal(contour[0], contour[-1]):
                contour = np.vstack([contour, contour[0]])
            # ax.fill()绘制并填充多边形
            #ax.fill(contour[:, 0], contour[:, 1], 'black', edgecolor='red', linewidth=0.5)
            # 只绘制轮廓'r-'表示红色实线是color='red', linestyle='-'的简写
            ax.plot(contour[:, 0], contour[:, 1], 'b-', linewidth=1)

        # 保存可视化结果
        FileOutputPath = os.path.splitext(FileInputPath)[0] + "_CDTofPore.png"
        plt.savefig(FileOutputPath, bbox_inches='tight', pad_inches=0, dpi=dpi)
        plt.show()
        plt.close()

    return B


